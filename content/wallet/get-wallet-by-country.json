  "type": "endpoint",
  "title": "Get Wallet by Country",
  "meta": {
    "description": "",
    "hidden": false
  },
  "method": "GET",
  "path": "/api/v1/wallet/{{country_code}}",
  "headers": [
    {
      "key": "x-api-key",
      "value": "{{secret_key}}",
      "description": ""
    },
    {
      "key": "Content-Type",
      "value": "application/json",
      "description": ""
    }
  ],
  "body": "",
  "params": [
    {
      "name": "country_code",
      "type": "string",
      "required": true,
      "description": "ISO 3166-1 alpha-2 country code for the wallet to retrieve. Vesicash maintains a separate wallet per supported country. Example: `GH` for Ghana, `ZM` for Zambia, `NG` for Nigeria, `KE` for Kenya."
    }
  ],
