    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Number of transactions to return per page. Defaults to `20`. Maximum allowed value is `100`."
    },
    {
      "name": "reference",
      "type": "string",
      "required": false,
      "description": "Filter results to a single transaction by its Vesicash reference string. Returns a list containing one item when a match is found."
