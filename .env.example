# ── Admin panel credentials ───────────────────────────────────────────────────
# Access code shown on the /x/login screen — keep this secret
ADMIN_ACCESS_CODE=

# Secret used to sign admin session tokens — generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=

# ── Cloudflare R2 storage ─────────────────────────────────────────────────────
# When these are set, content is read/written from R2 (production).
# When unset, the local filesystem is used instead (local dev).
#
# CF_ACCOUNT_ID  — found on the right sidebar of dash.cloudflare.com
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY — from R2 → Manage R2 API Tokens
# R2_BUCKET_NAME — the name of your R2 bucket
CF_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
